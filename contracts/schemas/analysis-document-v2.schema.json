{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aether.invalid/contracts/schemas/analysis-document-v2.schema.json",
  "title": "AETHER AnalysisDocumentV2",
  "type": "object",
  "required": [
    "schemaVersion",
    "item",
    "algorithm",
    "createdAt",
    "storedAt",
    "durationMs",
    "sampling",
    "producer",
    "representation",
    "frames"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "item": {
      "type": "object",
      "required": ["id", "mediaSourceId", "fingerprint", "fingerprintQuality"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "mediaSourceId": {
          "type": "string",
          "minLength": 1
        },
        "fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "fingerprintQuality": {
          "enum": ["strong", "weak"]
        }
      }
    },
    "algorithm": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "storedAt": {
      "type": "string",
      "format": "date-time"
    },
    "durationMs": {
      "type": "integer",
      "minimum": 1
    },
    "sampling": {
      "$ref": "analysis-upload-v2.schema.json#/$defs/sampling"
    },
    "producer": {
      "$ref": "analysis-upload-v2.schema.json#/$defs/producer"
    },
    "representation": {
      "type": "object",
      "required": ["detail", "sourceIntervalMs", "derived", "reductionVersion"],
      "properties": {
        "detail": {
          "enum": ["compact", "balanced", "full"]
        },
        "sourceIntervalMs": {
          "type": "integer",
          "minimum": 1
        },
        "derived": {
          "type": "boolean"
        },
        "reductionVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        }
      }
    },
    "clientContentFingerprint": {
      "$ref": "analysis-upload-v2.schema.json#/$defs/clientContentFingerprint"
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "maxItems": 86400,
      "items": {
        "$ref": "analysis-upload-v2.schema.json#/$defs/frame"
      }
    },
    "audioFrames": {
      "type": "array",
      "maxItems": 864000,
      "items": {
        "$ref": "analysis-upload-v2.schema.json#/$defs/audioFrame"
      }
    }
  }
}
